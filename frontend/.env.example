# ── Local development ───────────────────────────────────────────────────────
# Leave VITE_API_BASE_URL empty (or omit it entirely) when running locally.
# The Vite dev server proxies /upload-url and /enroll → http://localhost:3001 automatically.
VITE_API_BASE_URL=

# ── Production (AWS) ────────────────────────────────────────────────────────
# Set this to your API Gateway stage URL when deploying to AWS (CloudFront + Lambda).
# Example: https://<api-id>.execute-api.<region>.amazonaws.com/prod
# VITE_API_BASE_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod
