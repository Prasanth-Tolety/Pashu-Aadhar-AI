# ── AWS Region ────────────────────────────────────────────────
# AWS region where the stack is deployed
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────
# Name of the S3 bucket used to store animal images
S3_BUCKET_NAME=pashu-aadhaar-images-dev

# ── SageMaker ─────────────────────────────────────────────────
# Name of the SageMaker endpoint for embedding generation
SAGEMAKER_ENDPOINT_NAME=pashu-aadhaar-embedding-endpoint

# ── OpenSearch ────────────────────────────────────────────────
# Full URL of the OpenSearch domain (including https://)
OPENSEARCH_ENDPOINT=https://search-pashu-aadhaar-xxxx.us-east-1.es.amazonaws.com

# Name of the OpenSearch index that stores embeddings
OPENSEARCH_INDEX=livestock-embeddings

# ── Matching ──────────────────────────────────────────────────
# Cosine similarity threshold for considering two animals a match (0-1)
SIMILARITY_THRESHOLD=0.85

# ── CORS ──────────────────────────────────────────────────────
# Allowed origin for CORS headers (use specific domain in production)
ALLOWED_ORIGIN=https://dcpr4zrh8k283.cloudfront.net/
