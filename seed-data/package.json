{
  "name": "pashu-aadhaar-seed-data",
  "version": "1.0.0",
  "description": "Seed script for Pashu Aadhaar AI — populates all DynamoDB tables with realistic Indian-context dummy data",
  "type": "module",
  "scripts": {
    "seed": "node seed.mjs",
    "seed:embeddings": "node seed-with-embeddings.mjs",
    "seed:dry-run": "DRY_RUN=true node seed.mjs",
    "clear": "node clear-tables.mjs",
    "clear:all": "node -e \"process.env.CLEAR_ALL='true'\" && set CLEAR_ALL=true && node clear-tables.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.1004.0",
    "@aws-sdk/credential-provider-node": "^3.972.18",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@opensearch-project/opensearch": "^3.5.1"
  }
}
